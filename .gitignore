# Byte-compiled / cache artefacts
__pycache__/
*.py[cod]
*$py.class

# Tool caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/

# Build / packaging
build/
dist/
*.egg-info/
*.egg
site/

# Virtual environments
.venv/
venv/
env/

# Editor / OS
.DS_Store
.idea/
.vscode/
*.swp

# Claude Code per-user settings (absolute-path permissions; do not share)
.claude/

# Note: the six cd-rules design assets (emblem-*.svg, wordmark-*.svg,
# tokens.css) are intentionally NOT ignored. Under Model B (CD 0.10), they
# are vendored at a pinned upstream commit and integrity-checked against
# assets/SOURCE.md. Fetch via `tools/fetch_assets.sh`, then commit.
